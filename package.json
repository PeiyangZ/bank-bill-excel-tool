{
  "name": "bank-bill-excel-tool",
  "version": "1.3.2",
  "description": "网银账单小助手",
  "main": "src/main.js",
  "author": "OpenAI Codex",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "icon:sync": "node scripts/sync-app-icon.js",
    "dist:win": "electron-builder --win",
    "dist:win:setup": "electron-builder --win nsis",
    "dist:win:portable": "electron-builder --win portable",
    "preview": "node scripts/render-preview.js",
    "preview:account": "node scripts/render-account-mapping-preview.js",
    "smoke": "node scripts/smoke-test.js"
  },
  "build": {
    "appId": "com.openai.bankbillexceltool",
    "productName": "网银账单小助手",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "assets/**/*",
      "COMMON枚举.xlsx",
      "index.html",
      "src/**/*",
      "scripts/**/*",
      "CHANGELOG.md",
      "README.md",
      "docs/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": "build/icon.ico",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12"
  }
}
